<Window x:Class="LockKeyOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LockKeyOverlay"
        Width="128"
        Height="32"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <Border x:Name="OverlayBorder"
            CornerRadius="6"
            Padding="6,0,8,0"
            Background="#1E90FF"
            Opacity="0.70"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
            MouseMove="Overlay_MouseMove"
            MouseLeftButtonUp="Overlay_MouseLeftButtonUp">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="StateIcon"
                   Grid.Column="0"
                   Width="20"
                   Height="20"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   Stretch="Uniform" />

            <TextBlock x:Name="StateText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Margin="0,0,8,0"
                       FontFamily="Consolas"
                       FontSize="13.5"
                       FontWeight="Bold"
                       Foreground="White"
                       Text="NUM LK OFF" />
        </Grid>
    </Border>
</Window>