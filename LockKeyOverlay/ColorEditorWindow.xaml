<Window x:Class="LockKeyOverlay.ColorEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor de color"
        Width="620"
        Height="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF6F7FB">
    <Window.Resources>
        <DrawingBrush x:Key="CheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,10,10"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFE9E9E9">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,10,10"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFD5D5D5">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,5,5"/>
                                <RectangleGeometry Rect="5,5,5,5"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#FFD9DCE7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FF2D3340"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo -->
        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Ajustes de color"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#FF1F2430"/>

                <!-- R -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="R" Style="{StaticResource LabelTextStyle}"/>

                    <Slider x:Name="RedSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="255"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="AnySlider_ValueChanged"
                            VerticalAlignment="Center"
                            Margin="4,0"/>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            CornerRadius="6"
                            Background="#FFF1F3F7"
                            BorderBrush="#FFE1E5EF"
                            BorderThickness="1"
                            Padding="6,3">
                        <TextBlock x:Name="RedValueText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <!-- G -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="G" Style="{StaticResource LabelTextStyle}"/>

                    <Slider x:Name="GreenSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="255"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="AnySlider_ValueChanged"
                            VerticalAlignment="Center"
                            Margin="4,0"/>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            CornerRadius="6"
                            Background="#FFF1F3F7"
                            BorderBrush="#FFE1E5EF"
                            BorderThickness="1"
                            Padding="6,3">
                        <TextBlock x:Name="GreenValueText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <!-- B -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="B" Style="{StaticResource LabelTextStyle}"/>

                    <Slider x:Name="BlueSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="255"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="AnySlider_ValueChanged"
                            VerticalAlignment="Center"
                            Margin="4,0"/>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            CornerRadius="6"
                            Background="#FFF1F3F7"
                            BorderBrush="#FFE1E5EF"
                            BorderThickness="1"
                            Padding="6,3">
                        <TextBlock x:Name="BlueValueText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <!-- Opacidad -->
                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="66"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Opacidad" Style="{StaticResource LabelTextStyle}"/>

                    <Slider x:Name="OpacitySlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="AnySlider_ValueChanged"
                            VerticalAlignment="Center"
                            Margin="4,0"/>

                    <Border Grid.Column="2"
                            Margin="8,0,0,0"
                            CornerRadius="6"
                            Background="#FFF1F3F7"
                            BorderBrush="#FFE1E5EF"
                            BorderThickness="1"
                            Padding="6,3">
                        <TextBlock x:Name="OpacityValueText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <!-- HEX -->
                <TextBlock Grid.Row="10"
                           Text="HEX"
                           Style="{StaticResource LabelTextStyle}"
                           Margin="0,0,0,6"/>

                <StackPanel Grid.Row="11" Orientation="Vertical">
                    <TextBox x:Name="HexTextBox"
                             Height="30"
                             Padding="8,4"
                             FontFamily="Consolas"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             TextChanged="HexTextBox_TextChanged"/>

                    <TextBlock x:Name="HexStatusText"
                               Margin="2,6,0,0"
                               Foreground="#FF6B7280"
                               Text="Formato: #RRGGBB o #RRGGBBAA"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Panel derecho -->
        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Vista previa"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#FF1F2430"/>

                <Border Grid.Row="2"
                        Height="120"
                        Background="{StaticResource CheckerBrush}"
                        BorderBrush="#FFD6DAE6"
                        BorderThickness="1"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Border x:Name="PreviewSampleBorder"
                                Margin="14"
                                CornerRadius="10"
                                BorderBrush="#66000000"
                                BorderThickness="1"
                                Background="#FFFF8C00"/>

                        <TextBlock x:Name="PreviewSampleText"
                                   Text="Preview"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        CornerRadius="8"
                        Background="#FFF1F3F7"
                        BorderBrush="#FFE1E5EF"
                        BorderThickness="1"
                        Padding="10,6">
                    <TextBlock x:Name="OpacityInfoText"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Botones -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="CancelButton"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"
                    Content="Cancelar"
                    Click="CancelButton_Click"/>

            <Button x:Name="OkButton"
                    Width="100"
                    Height="32"
                    Content="OK"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>